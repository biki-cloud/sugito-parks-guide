---
import Layout from '../layouts/Layout.astro';
---
<Layout title="404 Not Found">
  <section class="notfound">
    <div class="notfound-inner">
      <p class="code">404</p>
      <h1>ページが見つかりません</h1>
      <p class="lead">お探しのページは存在しないか、移動した可能性があります。</p>
      <a href="/" class="home-link">トップページへ戻る →</a>
    </div>
  </section>
</Layout>

<style>
  .notfound {
    min-height: 70vh; display: flex; align-items: center; justify-content: center;
    text-align: center; padding: 8rem 1.5rem 4rem; background: var(--color-bg);
  }
  .notfound-inner { max-width: 480px; }
  .code { font-size: 5rem; font-weight: 700; line-height: 1; color: #0ea5e9; margin-bottom: 1.5rem; }
  .notfound h1 { font-size: 1.5rem; font-weight: 700; color: #1e3a5f; margin-bottom: 1rem; }
  .lead { font-size: 0.9rem; color: var(--color-sub); line-height: 1.8; margin-bottom: 2.5rem; }
  .home-link {
    display: inline-block; padding: 0.9rem 2rem;
    background: linear-gradient(135deg, #1e3a5f 0%, #0ea5e9 100%);
    color: #ffffff; font-size: 0.9rem; font-weight: 600; text-decoration: none; transition: opacity 0.2s;
  }
  .home-link:hover { opacity: 0.9; }
</style>
